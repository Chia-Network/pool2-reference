[run]
branch=True
disable_warnings=
  module-not-measured
relative_files=True
source =
  chia-pool
concurrency=multiprocessing, thread
parallel=True

[paths]
source =
  chia-pool/

[report]
precision = 1
exclude_also =
  abc\.abstractmethod
  typing\.overload
  ^\s*\.\.\.\s*$
  if typing.TYPE_CHECKING:
  if TYPE_CHECKING:
  ^ *@pytest.mark.skip($|\()
